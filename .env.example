# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=d6e
POSTGRES_PORT=5432

# Database URL
DATABASE_URL=postgres://postgres:your-secure-password@db:5432/d6e

# API Service
API_PORT=8080

# MCP Service
MCP_PORT=8081

# Frontend Configuration
FRONTEND_PORT=3000
D6E_API_URL=http://api:8080
D6E_MCP_SERVER_URL=http://mcp:8081/mcp

# Origin for SvelteKit (required when running behind a reverse proxy)
# Also used by API server for OAuth redirect URI validation
ORIGIN=http://localhost:3000

# Container Token Secret
# Secret key for signing Docker container authentication tokens
# Generate a secure random string for production (e.g., openssl rand -base64 32)
D6E_CONTAINER_TOKEN_SECRET=d6e-container-secret-dev-key

# d6e-auth Configuration (external authentication service)
# D6E_AUTH_URL is used by both frontend and API to fetch JWT public keys
# from the JWKS endpoint (D6E_AUTH_URL/.well-known/jwks.json).
# This enables automatic key rotation without service restarts.
D6E_AUTH_URL=https://www.d6e.ai
D6E_AUTH_CLIENT_ID=your-client-id
D6E_AUTH_CLIENT_SECRET=your-client-secret
# JWT issuer claim to validate (defaults to D6E_AUTH_URL then "d6e-auth")
D6E_AUTH_JWT_ISSUER=d6e-auth

# LLM API Keys (optional - only needed for AI features)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Embedding Configuration (optional - only needed for similarity search features)
# Requires GOOGLE_API_KEY to be set above
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
